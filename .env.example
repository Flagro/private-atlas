# Database (PostgreSQL)
# After running `docker compose up -d`, use this connection string
# Required in production (validated at Node.js startup via instrumentation.ts)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/private_atlas?schema=public"

# Auth (Phase 1+)
# Generate with: npx auth secret
# Required in production (validated at Node.js startup via instrumentation.ts)
AUTH_SECRET="generate-with-npx-auth-secret"

# Canonical public URL (production / non-localhost). Helps OAuth callbacks and auth URLs.
# Example: AUTH_URL="https://your-domain.com"
# AUTH_URL="http://localhost:3000"

# OAuth — Google (Phase 5)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:3000/api/auth/callback/google as an Authorized redirect URI
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Security / abuse resistance
# Middleware rate-limits POSTs under /api/auth (register, credential sign-in, other Auth.js routes).
# LIMITATIONS: counters are per server/Edge instance and reset on cold start. For fleet-wide limits,
# add Redis/Upstash and wire keys by client IP (+ optional fingerprint).
#
# CSP is applied in production only (see next.config.ts). Set DISABLE_SECURITY_CSP=1 to opt out during debugging.
# Set FORCE_HSTS=1 ONLY when serving the app over HTTPS in production (not on plain http:// localhost).
#
# DISABLE_SECURITY_CSP=""
# FORCE_HSTS=""
