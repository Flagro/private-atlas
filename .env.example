# Database (PostgreSQL)
# After running `docker compose up -d`, use this connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/private_atlas?schema=public"

# Auth (Phase 1+)
# Generate with: npx auth secret
AUTH_SECRET="generate-with-npx-auth-secret"

# Canonical public URL (production / non-localhost). Helps OAuth callbacks and auth URLs.
# Example: AUTH_URL="https://your-domain.com"
# AUTH_URL="http://localhost:3000"

# OAuth — Google (Phase 5)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:3000/api/auth/callback/google as an Authorized redirect URI
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
